# ╔══════════════════════════════════════════════════════════════╗
# ║  Banking System — Environment Variables (.env.example)     ║
# ║  คัดลอกไฟล์นี้เป็น .env แล้วแก้ไขค่าให้ตรงกับ environment  ║
# ╚══════════════════════════════════════════════════════════════╝

# ===== Environment =====
# ค่าที่ใช้ได้: Debug | Development | UAT | Production
ASPNETCORE_ENVIRONMENT=Development

# ===== Database =====
DB_HOST=localhost
DB_PORT=5432
DB_NAME=banking_dev
DB_USERNAME=postgres
DB_PASSWORD=root1234

# Connection String (ใช้ค่าข้างบนประกอบ หรือตั้งตรงๆ ก็ได้)
# ConnectionStrings__DefaultConnection=Host=${DB_HOST};Port=${DB_PORT};Database=${DB_NAME};Username=${DB_USERNAME};Password=${DB_PASSWORD}
