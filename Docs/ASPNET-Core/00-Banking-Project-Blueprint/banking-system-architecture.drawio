<mxfile host="app.diagrams.net">
  <diagram id="arch" name="System Architecture">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title1" value="Banking System - Architecture Flow" style="text;html=1;fontSize=24;fontStyle=1;align=center;fillColor=none;strokeColor=none;" vertex="1" parent="1"><mxGeometry x="400" y="20" width="500" height="40" as="geometry"/></mxCell>
        <mxCell id="client_group" value="Client Layer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="20" y="80" width="250" height="200" as="geometry"/></mxCell>
        <mxCell id="browser" value="Next.js Frontend&#xa;(React + TypeScript)&#xa;&#xa;- Dashboard&#xa;- Deposit / Withdraw&#xa;- Transfer&#xa;- Transaction History" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="35" y="110" width="220" height="150" as="geometry"/></mxCell>
        <mxCell id="api_gw" value="API Gateway / Load Balancer&#xa;(Nginx / YARP)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="350" y="80" width="250" height="50" as="geometry"/></mxCell>
        <mxCell id="api_group" value="ASP.NET Core API (.NET 10)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="310" y="160" width="330" height="380" as="geometry"/></mxCell>
        <mxCell id="ctrl" value="Controllers&#xa;AccountController&#xa;TransactionController&#xa;AuthController" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="330" y="195" width="140" height="90" as="geometry"/></mxCell>
        <mxCell id="middleware" value="Middleware&#xa;JWT Auth&#xa;Rate Limiting&#xa;Exception Handler&#xa;Audit Logging" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="480" y="195" width="140" height="90" as="geometry"/></mxCell>
        <mxCell id="app_layer" value="Application Layer (CQRS + MediatR)&#xa;&#xa;Commands: Deposit, Withdraw, Transfer&#xa;Queries: GetBalance, GetTransactions&#xa;Validators: FluentValidation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="330" y="300" width="290" height="90" as="geometry"/></mxCell>
        <mxCell id="domain" value="Domain Layer&#xa;&#xa;Entities: User, Account, Transaction, Transfer&#xa;Business Rules: Balance, Daily limit, Status" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="330" y="405" width="290" height="80" as="geometry"/></mxCell>
        <mxCell id="infra" value="Infrastructure Layer&#xa;EF Core + Repositories + UnitOfWork" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1"><mxGeometry x="330" y="500" width="290" height="30" as="geometry"/></mxCell>
        <mxCell id="db_group" value="Data Layer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=14;fontStyle=1;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="720" y="160" width="280" height="250" as="geometry"/></mxCell>
        <mxCell id="postgres" value="PostgreSQL&#xa;&#xa;users, accounts,&#xa;transactions, transfers,&#xa;audit_logs" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1"><mxGeometry x="740" y="200" width="120" height="100" as="geometry"/></mxCell>
        <mxCell id="redis" value="Redis&#xa;&#xa;Session Cache&#xa;Rate Limit Counter&#xa;Real-time Pub/Sub" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1"><mxGeometry x="870" y="200" width="120" height="100" as="geometry"/></mxCell>
        <mxCell id="realtime_group" value="Real-time Layer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;fontStyle=1;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="720" y="430" width="280" height="110" as="geometry"/></mxCell>
        <mxCell id="signalr" value="SignalR Hub&#xa;&#xa;Balance updates (real-time)&#xa;Transaction notifications&#xa;Account alerts" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="735" y="460" width="250" height="70" as="geometry"/></mxCell>
        <mxCell id="ext_group" value="External Services" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=14;fontStyle=1;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="1080" y="80" width="200" height="200" as="geometry"/></mxCell>
        <mxCell id="serilog" value="Serilog&#xa;Structured Logging" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1"><mxGeometry x="1095" y="110" width="170" height="40" as="geometry"/></mxCell>
        <mxCell id="email_svc" value="Email Service&#xa;(SendGrid/SMTP)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1"><mxGeometry x="1095" y="160" width="170" height="40" as="geometry"/></mxCell>
        <mxCell id="health" value="Health Checks&#xa;/health endpoint" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1"><mxGeometry x="1095" y="210" width="170" height="40" as="geometry"/></mxCell>
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="browser" target="api_gw" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e1_label" value="HTTPS" style="edgeLabel;html=1;fontSize=10;" vertex="1" connectable="0" parent="e1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="api_gw" target="ctrl" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="ctrl" target="app_layer" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="app_layer" target="domain" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="domain" target="infra" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="infra" target="postgres" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;rounded=1;dashed=1;" edge="1" source="infra" target="redis" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;rounded=1;dashed=1;strokeColor=#D4A843;" edge="1" source="api_group" target="signalr" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;rounded=1;dashed=1;strokeColor=#D4A843;" edge="1" source="signalr" target="browser" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e9_label" value="WebSocket" style="edgeLabel;html=1;fontSize=10;" vertex="1" connectable="0" parent="e9"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="flow_title" value="Request Flow:  Browser &gt; Nginx LB &gt; JWT Auth &gt; Controller &gt; MediatR &gt; Handler &gt; Domain Logic &gt; EF Core &gt; PostgreSQL &gt; Response" style="text;html=1;fontSize=12;fillColor=#fff2cc;strokeColor=#d6b656;rounded=1;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="20" y="570" width="980" height="30" as="geometry"/></mxCell>
        <mxCell id="deposit_flow" value="Deposit Flow:&#xa;1. User clicks Deposit&#xa;2. Next.js &gt; POST /api/transactions/deposit&#xa;3. JWT validated &gt; DepositCommand created&#xa;4. FluentValidation checks (amount &gt; 0, account active)&#xa;5. Domain: check account status, update balance&#xa;6. EF Core: BEGIN TX &gt; INSERT transaction + UPDATE account &gt; COMMIT&#xa;7. Redis: invalidate cache + publish balance update&#xa;8. SignalR: push new balance to client&#xa;9. Return 200 + transaction details" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="20" y="620" width="480" height="170" as="geometry"/></mxCell>
        <mxCell id="withdraw_flow" value="Withdraw Flow:&#xa;1. User clicks Withdraw&#xa;2. Next.js &gt; POST /api/transactions/withdraw&#xa;3. JWT validated &gt; WithdrawCommand created&#xa;4. Validation: amount &gt; 0, account active&#xa;5. Domain: check balance &gt;= amount, daily limit check&#xa;6. Redis: get today withdrawal total&#xa;7. EF Core: BEGIN TX &gt; INSERT transaction + UPDATE account &gt; COMMIT&#xa;8. If balance &lt; amount &gt; throw InsufficientFundsException&#xa;9. SignalR: push updated balance" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="520" y="620" width="480" height="170" as="geometry"/></mxCell>
        <mxCell id="transfer_flow" value="Transfer Flow:&#xa;1. User enters recipient account + amount&#xa;2. POST /api/transfers&#xa;3. Validate: both accounts exist, active, sufficient balance&#xa;4. Domain: debit from_account, credit to_account&#xa;5. EF Core: BEGIN TX &gt; 2x INSERT transactions + 2x UPDATE accounts + 1x INSERT transfer &gt; COMMIT&#xa;6. Redis: invalidate both account caches&#xa;7. SignalR: notify both users of balance change" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="20" y="810" width="480" height="130" as="geometry"/></mxCell>
        <mxCell id="auth_flow" value="Auth Flow:&#xa;1. POST /api/auth/login (email + password)&#xa;2. BCrypt verify password hash&#xa;3. If failed 5x &gt; lock account&#xa;4. Generate JWT (access token 15min + refresh token 7d)&#xa;5. Store refresh token in Redis&#xa;6. Return tokens + user info&#xa;7. Next.js stores in httpOnly cookie&#xa;8. Every request: Authorization: Bearer {token}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="520" y="810" width="480" height="130" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
